# InfluQ — environment variables
# Copy to .env.local for local dev, and set the same in your host (Vercel).
# NEXT_PUBLIC_* values are inlined at BUILD time → a redeploy is required after changing them.

# --- Supabase (required for auth + DB) ---
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx        # public/publishable key (safe in browser)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx                 # SECRET — server only, bypasses RLS

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://www.influq.com             # canonical URL (metadata, robots, sitemap, OG)

# --- AI (script + coach generation; falls back to a deterministic engine if unset) ---
OPENAI_API_KEY=sk-proj-xxx
GEMINI_API_KEY=                                         # optional alternate engine

# --- Encryption (for stored secrets) ---
ENCRYPTION_KEY=                                         # 64-char hex

# --- Payments (Razorpay; verify route stays inert until set) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# --- Analytics / monitoring (optional) ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_CLARITY_PROJECT_ID=
SENTRY_AUTH_TOKEN=

# --- Local migrations ONLY (do NOT set on Vercel; contains the DB password) ---
# DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
